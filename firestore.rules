rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // User Profile
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.get('displayName', '') is string &&
             data.get('photoURL', '') is string &&
             data.get('createdAt', 0) is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'createdAt']);
    }

    // Estimates
    function isValidEstimate(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'createdAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.type is string && data.type.size() <= 100 &&
             data.createdAt is number;
    }

    match /estimates/{estimateId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(estimateId) && isValidEstimate(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidId(estimateId) && isValidEstimate(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'payload']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
