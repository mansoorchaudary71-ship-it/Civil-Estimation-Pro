{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Estimate": {
      "title": "Estimate",
      "description": "Saved estimation records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "object" },
        "createdAt": { "type": "number", "description": "Server Timestamp" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/estimates/{estimateId}": {
      "schema": { "$ref": "#/entities/Estimate" },
      "description": "Saved estimates for users"
    }
  }
}
